# Day 5 以降で backend/.env にコピーして使用（.env は Git に含めない）
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=learning_app

# Day 11: JWT 認証（JWT_SECRET は長いランダム文字列に変更すること）
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRE_MINUTES=1440

# Day 14: 本番フロント URL（カンマ区切り・末尾スラッシュなし）
# 例: CORS_ORIGINS=https://your-app.vercel.app
CORS_ORIGINS=
